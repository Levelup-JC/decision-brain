{
  "name": "decision-brain",
  "version": "0.1.0",
  "private": true,
  "description": "Decision Brain MVP: an investment memory and recommendation layer for trading agents.",
  "type": "module",
  "scripts": {
    "start": "node src/index.mjs",
    "start:lobster": "node src/scripts/start-lobster-http.mjs",
    "dev": "node --watch src/index.mjs",
    "test": "node --test test/*.test.mjs",
    "bstc": "node tests/bstc-runner.mjs",
    "monitor:daily": "node src/scripts/run-daily-monitor.mjs",
    "mcp": "node src/mcp-server.mjs",
    "mcp:lobster": "node src/scripts/start-lobster-mcp.mjs",
    "reset:state": "node src/scripts/reset-state.mjs",
    "demo:flow": "node src/scripts/demo-flow.mjs --reset",
    "bootstrap:lobster": "node src/scripts/bootstrap-lobster-config.mjs",
    "install:lobster": "node src/scripts/install-lobster-config.mjs",
    "install:lobster:auto": "node src/scripts/install-lobster-auto.mjs",
    "discover:lobster": "node src/scripts/discover-mcp-configs.mjs",
    "verify:lobster": "node src/scripts/verify-lobster-install.mjs"
  },
  "keywords": [
    "mcp",
    "agent",
    "bitget",
    "investment",
    "decision-brain",
    "lobster"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vercel/kv": "^3.0.0"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "undici": "^8.5.0"
  }
}
